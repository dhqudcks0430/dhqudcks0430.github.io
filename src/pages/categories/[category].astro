---
import PageHero from '@/components/PageHero.astro';
import WriteupCard from '@/components/WriteupCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCategoryLabel, getCategoryMap, getPublishedWriteups } from '@/lib/content';

export async function getStaticPaths() {
  const writeups = await getPublishedWriteups();
  const categories = getCategoryMap(writeups);

  return categories.map(({ term, writeups: groupedWriteups }) => ({
    params: { category: term },
    props: {
      category: term,
      writeups: groupedWriteups
    }
  }));
}

const { category, writeups } = Astro.props;
---

<BaseLayout title={`카테고리: ${getCategoryLabel(category)}`} description={`${getCategoryLabel(category)} 카테고리의 글 모음입니다.`} pathname={`/categories/${category}`}>
  <PageHero eyebrow="카테고리" title={getCategoryLabel(category)} description={`${getCategoryLabel(category)} 글을 주제 중심으로 모은 아카이브 페이지입니다.`} />

  <section class="site-shell section-spacing">
    <div class="card-grid">
      {writeups.map((entry) => (
        <WriteupCard entry={entry} />
      ))}
    </div>
  </section>
</BaseLayout>
