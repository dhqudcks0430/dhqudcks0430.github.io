---
import PageHero from '@/components/PageHero.astro';
import WriteupCard from '@/components/WriteupCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedWriteups, getTagMap } from '@/lib/content';

export async function getStaticPaths() {
  const writeups = await getPublishedWriteups();
  const tags = getTagMap(writeups);

  return tags.map(({ term, writeups: taggedWriteups }) => ({
    params: { tag: term },
    props: {
      tag: term,
      writeups: taggedWriteups
    }
  }));
}

const { tag, writeups } = Astro.props;
---

<BaseLayout title={`태그: ${tag}`} description={`${tag} 태그가 붙은 글 모음입니다.`} pathname={`/tags/${tag}`}>
  <PageHero eyebrow="태그" title={`#${tag}`} description={`게시된 모든 글에서 ${tag} 태그를 모아 생성한 목록입니다.`} />

  <section class="site-shell section-spacing">
    <div class="card-grid">
      {writeups.map((entry) => (
        <WriteupCard entry={entry} />
      ))}
    </div>
  </section>
</BaseLayout>
