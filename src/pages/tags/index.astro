---
import PageHero from '@/components/PageHero.astro';
import TaxonomyCard from '@/components/TaxonomyCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedWriteups, getTagMap } from '@/lib/content';

const writeups = await getPublishedWriteups();
const tags = getTagMap(writeups);
---

<BaseLayout title="Tags" description="Browse all tag taxonomies generated from writeup metadata." pathname="/tags">
  <PageHero eyebrow="Taxonomy" title="Tags" description="Normalized tag listings generated from MDX frontmatter so filtering stays consistent as the archive grows." />

  <section class="site-shell section-spacing">
    <div class="taxonomy-grid">
      {tags.map(({ term, writeups: taggedWriteups }) => (
        <TaxonomyCard title={`#${term}`} description={taggedWriteups[0]?.data.summary ?? 'Tag archive'} href={`/tags/${term}`} count={taggedWriteups.length} />
      ))}
    </div>
  </section>
</BaseLayout>
