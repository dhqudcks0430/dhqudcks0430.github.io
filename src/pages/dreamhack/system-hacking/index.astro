---
import PageHero from '@/components/PageHero.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import StatCard from '@/components/StatCard.astro';
import WriteupCard from '@/components/WriteupCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedWriteups, getTrackWriteups } from '@/lib/content';

const writeups = getTrackWriteups(await getPublishedWriteups(), 'dreamhack-system-hacking');
---

<BaseLayout title="DreamHack System Hacking" description="Landing page for DreamHack system-hacking writeups and progress notes." pathname="/dreamhack/system-hacking">
  <PageHero eyebrow="Learning Track" title="DreamHack System Hacking" description="A curated static archive of DreamHack system-hacking writeups, from classic BOF drills to leak-driven libc reuse." />

  <section class="site-shell section-spacing">
    <div class="stats-grid">
      <StatCard label="Writeups" value={writeups.length} description="Published DreamHack entries in this track." />
      <StatCard label="Featured" value={writeups.filter((entry) => entry.data.featured).length} description="Highlighted entries surfaced on the home page." />
      <StatCard label="Focus" value="Binary exploitation" description="Stack control, shellcode, leaks, and format string practice." />
    </div>
  </section>

  <section class="site-shell section-spacing">
    <SectionHeader title="Track entries" description="Every page below is generated from collection metadata and rendered through the same technical writeup layout." />
    <div class="card-grid">
      {writeups.map((entry) => (
        <WriteupCard entry={entry} />
      ))}
    </div>
  </section>
</BaseLayout>
