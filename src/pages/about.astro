---
import ContentPageLayout from '@/layouts/ContentPageLayout.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import StatCard from '@/components/StatCard.astro';
import { getPageByKind, getPublishedWriteups } from '@/lib/content';
import { render } from 'astro:content';

const page = await getPageByKind('about');

if (!page) {
  throw new Error('About page content entry is missing.');
}

const writeups = await getPublishedWriteups();
const { Content } = await render(page);
---

<ContentPageLayout title={page.data.title} description={page.data.description} eyebrow="작업 방식" pathname={page.data.canonicalPath}>
  <Content />

  <section class="section-spacing">
    <SectionHeader title="현재 프로필 스냅샷" description="샘플 콘텐츠를 본인 작업으로 바꾸기 전에도 포트폴리오가 살아 보이도록 하는 고정 하이라이트입니다." />
    <div class="stats-grid">
      <StatCard label="글 수" value={writeups.length} description="아카이브, 태그, 카테고리 생성에 이미 연결된 샘플 글입니다." />
      <StatCard label="디자인" value="다크 우선" description="긴 기술 문서를 읽기 좋게 조정한 프리미엄 미니멀 스타일입니다." />
      <StatCard label="배포" value="깃허브 페이지" description="Pages 호스팅에 맞춘 정적 출력과 워크플로 구성이 준비되어 있습니다." />
    </div>
  </section>
</ContentPageLayout>
