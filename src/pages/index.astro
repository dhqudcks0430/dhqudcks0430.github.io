---
import ContentPageLayout from '@/layouts/ContentPageLayout.astro';
import { getCategoryLabel, getCategoryMap, getPageByKind, getPublishedWriteups, getTagMap } from '@/lib/content';
import { withBase } from '@/lib/site';

const page = await getPageByKind('home');

if (!page) {
  throw new Error('Home page content entry is missing.');
}

const writeups = await getPublishedWriteups();
const allTags = getTagMap(writeups);
const categoryMap = getCategoryMap(writeups);
const featuredCategories = categoryMap.slice(0, 3);
---

<ContentPageLayout title={page.data.title} description={page.data.description} eyebrow="개발자 포트폴리오 + 글 모음" pathname={page.data.canonicalPath}>
  <Fragment slot="hero">
    <div class="hero-signal-grid">
      <div class="hero-intro-strip surface">
        <span>서울 기반 학습 아카이브</span>
        <span>{writeups.length}개 게시 글</span>
        <span>{allTags.length}개 태그</span>
      </div>

      <div class="hero-actions">
        <a class="button-link" href={withBase('/archive')}>아카이브 보기</a>
        <a class="button-link" data-variant="ghost" href={withBase('/dreamhack/system-hacking')}>드림핵 트랙</a>
        <a class="button-link" data-variant="ghost" href={withBase('/pwnable-kr')}>pwnable.kr 트랙</a>
      </div>

      <div class="hero-signal-card surface">
        <span class="hero-signal-card__label">현재 집중</span>
        <strong>시스템 해킹, 바이너리 익스플로잇, 재현 가능한 글쓰기</strong>
        <p>편집 기사 첫 화면처럼 구성한 기술 아카이브입니다. 더 강한 타이포그래피, 촘촘한 메타데이터, 더 빠른 문제 트랙 진입을 목표로 합니다.</p>
      </div>

      <div class="hero-signal-card surface">
        <span class="hero-signal-card__label">추천 카테고리</span>
        <div class="hero-signal-card__list">
          {featuredCategories.map(({ term, writeups: groupedWriteups }) => (
            <a href={withBase(`/categories/${term}`)}>
              <span>{getCategoryLabel(term)}</span>
              <strong>{groupedWriteups.length}</strong>
            </a>
          ))}
        </div>
      </div>
    </div>
  </Fragment>
</ContentPageLayout>
