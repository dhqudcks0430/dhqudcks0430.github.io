---
import ContentPageLayout from '@/layouts/ContentPageLayout.astro';
import { getPageByKind, getPublishedOpenCheckPosts, getPublishedWriteups, getTagMap } from '@/lib/content';
import { withBase } from '@/lib/site';

const page = await getPageByKind('home');

if (!page) {
  throw new Error('Home page content entry is missing.');
}

const writeups = await getPublishedWriteups();
const opencheckPosts = await getPublishedOpenCheckPosts();
const allTags = getTagMap(writeups);
---

<ContentPageLayout title={page.data.title} description={page.data.description} eyebrow="개발일지 기록" pathname={page.data.canonicalPath}>
  <Fragment slot="hero">
    <div class="hero-signal-grid">
      <div class="hero-intro-strip surface">
        <span>개발일지</span>
        <span>{writeups.length + opencheckPosts.length}개 기록</span>
        <span>{allTags.length}개 태그</span>
      </div>

      <div class="hero-actions">
        <a class="button-link" href={withBase('/opencheck')}>OpenCheck</a>
        <a class="button-link" data-variant="ghost" href={withBase('/dreamhack/system-hacking')}>시스템 해킹</a>
        <a class="button-link" data-variant="ghost" href={withBase('/study')}>공부 기록</a>
      </div>

      <div class="hero-signal-card surface">
        <span class="hero-signal-card__label">현재 집중</span>
        <strong>OpenCheck 제작, 보안 공부, 꾸준한 개발일지</strong>
        <p>완성된 결과보다 만드는 과정과 판단을 남기는 블로그입니다. 오늘 한 일, 막힌 점, 다음 작업을 읽기 쉽게 정리합니다.</p>
      </div>

      <div class="hero-signal-card surface">
        <span class="hero-signal-card__label">주제 바로가기</span>
        <div class="hero-signal-card__list">
          <a href={withBase('/opencheck')}><span>OpenCheck</span><strong>{opencheckPosts.length}</strong></a>
          <a href={withBase('/dreamhack/system-hacking')}><span>시스템 해킹</span><strong>{writeups.length}</strong></a>
          <a href={withBase('/gap-year')}><span>갭이어</span><strong>기록</strong></a>
        </div>
      </div>
    </div>
  </Fragment>
</ContentPageLayout>
