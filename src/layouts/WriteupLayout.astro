---
import Pill from '@/components/Pill.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import {
  formatDate,
  getCategoryLabel,
  getDifficultyLabel,
  getPlatformLabel,
  getStatusLabel,
  type WriteupEntry
} from '@/lib/content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: WriteupEntry;
  headings: Heading[];
  pathname?: string | undefined;
}

const { entry, headings, pathname } = Astro.props;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.seoDescription ?? entry.data.description}
  pathname={pathname ?? entry.data.canonicalPath ?? Astro.url.pathname}
  pageType="article"
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  tags={entry.data.tags}
>
  <PageHero
    eyebrow={getPlatformLabel(entry.data.platform)}
    title={entry.data.title}
    description={entry.data.description}
  >
    <div class="cluster">
      <Pill variant="accent">{getCategoryLabel(entry.data.topic)}</Pill>
      <Pill>{getDifficultyLabel(entry.data.difficulty)}</Pill>
      <Pill>{getStatusLabel(entry.data.status)}</Pill>
      <Pill>{formatDate(entry.data.publishedAt)}</Pill>
      {entry.data.updatedAt && <Pill>Updated {formatDate(entry.data.updatedAt)}</Pill>}
    </div>
  </PageHero>

  <section class="site-shell section-spacing">
    <div class="content-layout">
      <article class="content-layout__article surface panel-card prose">
        <slot />
      </article>

      <aside class="content-layout__sidebar">
        <section class="surface sidebar-card">
          <h3>Challenge Snapshot</h3>
          <ul class="meta-list">
            <li><strong>Challenge:</strong> {entry.data.challengeName}</li>
            <li><strong>Target:</strong> {entry.data.targetType}</li>
            <li><strong>OS:</strong> {entry.data.operatingSystem}</li>
            <li><strong>Summary:</strong> {entry.data.summary}</li>
          </ul>
        </section>

        <section class="surface sidebar-card">
          <h3>Tech Stack</h3>
          <div class="cluster">
            {entry.data.tools.map((tool) => (
              <Pill>{tool}</Pill>
            ))}
            {entry.data.techniques.map((technique) => (
              <Pill variant="accent">{technique}</Pill>
            ))}
          </div>
        </section>

        <section class="surface sidebar-card">
          <h3>Tags</h3>
          <div class="cluster">
            {entry.data.tags.map((tag) => (
              <Pill href={`/tags/${tag}`}>#{tag}</Pill>
            ))}
          </div>
        </section>

        <section class="surface sidebar-card">
          <h3>On this page</h3>
          <ul class="toc-list">
            {toc.map((heading) => (
              <li data-level={String(heading.depth)}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
