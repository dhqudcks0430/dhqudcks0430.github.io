---
import Pill from '@/components/Pill.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { formatDate, type OpenCheckEntry } from '@/lib/content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: OpenCheckEntry;
  headings: Heading[];
  pathname?: string | undefined;
}

const AREA_LABELS: Record<OpenCheckEntry['data']['area'], string> = {
  planning: '기획',
  backend: '백엔드',
  frontend: '프론트엔드',
  analysis: '분석',
  docs: '문서',
  release: '배포'
};

const STATUS_LABELS: Record<OpenCheckEntry['data']['status'], string> = {
  planned: '예정',
  'in-progress': '진행 중',
  shipped: '배포됨',
  reviewed: '검토 완료'
};

const { entry, headings, pathname } = Astro.props;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.seoDescription ?? entry.data.description}
  pathname={pathname ?? entry.data.canonicalPath ?? Astro.url.pathname}
  pageType="article"
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  tags={entry.data.tags}
>
  <PageHero eyebrow="OpenCheck" title={entry.data.title} description={entry.data.description}>
    <div class="cluster">
      <Pill variant="accent">{AREA_LABELS[entry.data.area]}</Pill>
      <Pill>{STATUS_LABELS[entry.data.status]}</Pill>
      <Pill>{formatDate(entry.data.publishedAt)}</Pill>
      {entry.data.updatedAt && <Pill>업데이트 {formatDate(entry.data.updatedAt)}</Pill>}
    </div>
  </PageHero>

  <section class="site-shell section-spacing">
    <div class="content-layout">
      <article class="content-layout__article surface panel-card prose">
        <slot />
      </article>

      <aside class="content-layout__sidebar">
        <section class="surface sidebar-card">
          <h3>프로젝트 노트</h3>
          <ul class="meta-list">
            <li><strong>영역:</strong> {AREA_LABELS[entry.data.area]}</li>
            <li><strong>상태:</strong> {STATUS_LABELS[entry.data.status]}</li>
            <li><strong>요약:</strong> {entry.data.summary}</li>
            {entry.data.repositoryUrl && (
              <li>
                <strong>저장소:</strong> <a href={entry.data.repositoryUrl}>GitHub</a>
              </li>
            )}
          </ul>
        </section>

        <section class="surface sidebar-card">
          <h3>다음 작업</h3>
          <ul class="meta-list">
            {entry.data.nextSteps.map((step) => (
              <li>{step}</li>
            ))}
          </ul>
        </section>

        <section class="surface sidebar-card">
          <h3>태그</h3>
          <div class="cluster">
            {entry.data.tags.map((tag) => (
              <Pill>#{tag}</Pill>
            ))}
          </div>
        </section>

        <section class="surface sidebar-card">
          <h3>이 페이지</h3>
          <ul class="toc-list">
            {toc.map((heading) => (
              <li data-level={String(heading.depth)}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
