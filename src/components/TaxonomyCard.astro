---
import { formatDate } from '@/lib/content';
import { withBase } from '@/lib/site';

interface Props {
  title: string;
  description: string;
  href: string;
  publishedAt?: Date | undefined;
}

const { title, description, href, publishedAt } = Astro.props;
const resolvedHref = withBase(href);
---

<a class="surface taxonomy-card" href={resolvedHref}>
  {publishedAt && <span class="taxonomy-card__date">{formatDate(publishedAt)}</span>}
  <h3>{title}</h3>
  <p>{description}</p>
</a>
