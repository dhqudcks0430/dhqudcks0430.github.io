---
import { SITE, withBase, withoutBase } from '@/lib/site';

const pathname = withoutBase(Astro.url.pathname).replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  const target = href.replace(/\/$/, '') || '/';
  return pathname === target || (target !== '/' && pathname.startsWith(`${target}/`));
};

const hasActiveItem = (items: readonly { href: string; label: string }[]) => items.some((item) => isActive(item.href));
---

<aside class="site-sidebar" aria-label="블로그 주제 탐색">
  <div class="sidebar-profile">
    <a class="sidebar-profile__mark" href={withBase('/')} aria-label="홈으로 이동">D</a>
    <div class="sidebar-profile__copy">
      <strong>{SITE.title}</strong>
      <span>{SITE.profile.role}</span>
    </div>
    <a class="sidebar-profile__link" href={SITE.github} rel="noreferrer" target="_blank">GitHub</a>
  </div>

  <nav class="sidebar-topics">
    {SITE.sidebarTopics.map((topic) => (
      <details class="sidebar-topic" open={hasActiveItem(topic.items)}>
        <summary class="sidebar-topic__header">
          <span>{topic.label}</span>
        </summary>
        <div class="sidebar-topic__links">
          {topic.items.map((item) => (
            <a href={withBase(item.href)} data-active={isActive(item.href) ? 'true' : 'false'}>
              {item.label}
            </a>
          ))}
        </div>
      </details>
    ))}
  </nav>

  <div class="sidebar-secondary">
    <strong class="sidebar-secondary__title">Page</strong>
    {SITE.nav.map((item) => (
      <a href={withBase(item.href)} data-active={isActive(item.href) ? 'true' : 'false'}>
        {item.label}
      </a>
    ))}
  </div>
</aside>
