---
import { withBase } from '@/lib/site';

interface Props {
  title: string;
  description: string;
  href?: string;
  linkLabel?: string;
}

const { title, description, href, linkLabel } = Astro.props;
const resolvedHref = href ? withBase(href) : undefined;
---

<div class="section-header">
  <div class="grid" style="gap:0.45rem;">
    <h2>{title}</h2>
    <p>{description}</p>
  </div>

  {href && linkLabel && (
    <a class="button-link" data-variant="ghost" href={resolvedHref}>
      {linkLabel}
    </a>
  )}
</div>
